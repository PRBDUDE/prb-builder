{
  "compilerOptions": {
    "baseUrl": "./",
    "target": "ESNext",
    "outDir": "./dist/builder",
    "rootDir": "./src/builder",
    "declaration": false,
    "module": "commonjs",
    "moduleResolution": "node",
    "noImplicitAny": true,
    "noImplicitThis": true,
    "noEmitOnError": true,
    "skipDefaultLibCheck": true,
    "skipLibCheck": true,
    "strictNullChecks": true,
    "sourceMap": false,
    "types": ["node"],
  },
  "include": [
    "src/builder/**/*"
  ],
  "exclude": ["node_modules"]
}

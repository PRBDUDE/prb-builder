{
  "name": "@prb/builder",
  "version": "0.0.1",
  "description": "Common builder functions used in development",
  "builders": "builders.json",
  "license": "ISC",
  "author": "PRBDude",
  "type": "commonjs",
  "main": "index.js",
  "scripts": {
    "build": "rimraf dist && tsc",
    "postbuild": "concurrently \"npm run copy:schema\" \"npm run copy:package\"",
    "copy:schema": "copyfiles --up 1 \"src/builder/**/*.json\" dist",
    "copy:package": "copyfiles package.json dist/builder",
    "build:watch": "tsc-watch --onSuccess \"npm run postbuild\"",
    "unpublish:package": "npm unpublish @prb/builder -f"
  },
  "devDependencies": {
    "@angular-devkit/architect": "^0.2003.8",
    "@angular-devkit/core": "^20.3.8",
    "@types/node": "^24.9.2",
    "concurrently": "^9.2.1",
    "copyfiles": "^2.4.1",
    "rimraf": "^6.1.0",
    "tsc-watch": "^7.2.0",
    "typescript": "^5.9.3"
  }
}
